@startuml CasosDeUso
left to right direction
actor Recepcionista
actor Medico 
actor Administrador 
actor Paciente 

rectangle "Sistema de Gestión Hospitalaria" {
    Recepcionista --> (Registrar Paciente)
    Recepcionista --> (Registar Alergia)
    Recepcionista --> (Consultar Historial Médico)
    Recepcionista --> (Agendar Cita)
    Recepcionista --> (Confirmar Cita)
    Medico --> (Registrar Diagnóstico)
    Medico --> (Registrar Receta)
    Medico --> (Marcar Cita En Atención)
    Medico --> (Marcar Cita Atendida)
    Administrador --> (Gestionar Personal)
    Administrador --> (Gestionar Turnos)
    Administrador --> (Generar Reportes)
    Administrador --> (Asignar Salario Base)
    Paciente --> (Solicitar Cita)
    Paciente --> (Consultar Resultados de Exámenes)
    Paciente --> (Consultar Historial Médico)
    Paciente --> (Cancelar Cita)
    
    (Agendar Cita) .> (Validar Disponibilidad Medico) : <<include>>
    (Registrar Diagnóstico) .> (Actualizar Historial Médico) : <<include>>
    (Registrar Receta) .> (Actualizar Historial) : <<include>>

    note right of (Agendar Cita)
      Validación: el médico no debe tener otra cita en la misma fecha y hora.
    end note

    note left of (Registrar Diagnóstico)
      El diagnóstico se registra en el historial del paciente.
    end note
}
@enduml
